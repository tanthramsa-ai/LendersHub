# Copy this file to ../.env (project root) and fill in the values.
# Never commit the actual .env file.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=lendershub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=production
# Used by the backend container (db = Docker service name)
DATABASE_URL=postgresql://postgres:change_me_strong_password@db:5432/lendershub
# Used by the seed script on the host (localhost because port 5433 is forwarded)
# DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5433/lendershub

JWT_SECRET=replace_with_random_64_char_secret

PORT=4001

# Base URL used to build tenant login links (path-based tenant routing).
# Dev: http://localhost:3000 -> links like http://localhost:3000/<subdomain>/login
APP_URL=http://localhost:3000

# Redis (Docker service name 'redis', port 6379 inside the container)
REDIS_HOST=redis
REDIS_PORT=6379

# ── SMTP (optional) ─────────────────────────────────────────────────────────
# Leave unset in development — Ethereal test emails are used automatically.
# Set these for real email delivery in production.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=LendersHub <noreply@lendershub.com>

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL the browser uses to call the API.
# For Docker Compose testing, backend is at http://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4001

# ── Super admin seed (used by: cd backend && npm run seed) ───────────────────
SUPER_ADMIN_EMAIL=admin@lendershub.com
SUPER_ADMIN_PASSWORD=Admin@LH2024!
